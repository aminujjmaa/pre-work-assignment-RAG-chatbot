
# RAG Scholar — LLM Provider Configuration
# LLM_PROVIDER: "groq", "nvidia", "gemini", or "auto" (tries all in order, failover on 429)
LLM_PROVIDER=auto

# ── Groq Cloud ── https://console.groq.com ──────────────────
# Free: 30 req/min, 14400 req/day
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# ── NVIDIA NIM ── https://build.nvidia.com ───────────────────
# Free: 1000 credits/month, runs 70B models (llama, mistral, etc.)
NVIDIA_API_KEY=
NVIDIA_MODEL=meta/llama-3.1-70b-instruct

# ── Google Gemini Flash ── https://aistudio.google.com ───────
# Free: 15 req/min, 1M tokens/day
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# ── Retrieval Settings ───────────────────────────────────────
CHUNK_SIZE_WORDS=500
CHUNK_OVERLAP_WORDS=80
TOP_K_RETRIEVE=8
TOP_K_RERANK=5
